steel_production = 50
gold_production = 150
food_production = 200
reputation = Array[String](["Nistral is the most impressive city of Nillia, which isn’t a particularly prestigious title. Like all cities in Nillia its primary source of food is fishing, but unlike the others Nistral is a fairly successful city for trade and a common stopping point for anyone wishing to travel north. "])

