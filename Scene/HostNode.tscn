[node name="Fimello" parent="Centers" unique_id=1316420759 instance=ExtResource("2_6oxiq")]
position = Vector2(616, 372)
token_name = "Fimello"
defense_bonus = 2.0
sworn_to = 2
ruled_by = "Rowan Bellari (Gustav)"
steel_production = 350
gold_production = 250
reputation = Array[String](["Fimello is the most famous city west of Crownport, it gets regular supplies of valuable metals from the grey peaks and is home to the world famous Torvano Palace. The palace is built next to the merging rivers and open to the public; it houses the greatest library ever seen. Scholars from all across the world come seeking wisdom. "])
function_one = Array[String](["Torvano Palace. An inspiring collection of books, maps and scholars.", "Minor Castle. This center has a minor castle, which can house 2500 soldiers and any important character. If a city is under siege, the ruling lord and his most loyal followers can hide here until help arrives. ", "Well funded poor houses with plenty of food"])

[node name="Silverhaven" parent="Centers" unique_id=526265324 instance=ExtResource("2_6oxiq")]
