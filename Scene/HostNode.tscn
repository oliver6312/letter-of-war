age = 19
traits = Array[String](["Cunning", "Rude", "Diplomatic", "Deceptive", "Wrathful"])
misc_list = Array[String](["The bastard daughter of the late king Alexander Taurus, born in a whore house in Silverhaven. Sarah bears a clear resemblance to her noble side. She has worked her way up into a position of power and has informants all around the coast of the Deep. Her ultimate goal is the end of House Taurus. "])

