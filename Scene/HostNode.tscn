[node name="Torr the Rabid" parent="." unique_id=2115889601 instance=ExtResource("5_uu6iq")]
position = Vector2(473, -51)
token_name = "Torr the Rabid"
army_size = 25000
sworn_to = 4
traits = Array[String](["Brutal", "Feared", "Loyal", "Battle Scared", "Insane"])
reputation = Array[String](["Torr the Rabid got his epithet from his many exploits in the civil war. He brutalized the entire coast of the Narrow. It is said that half of the coming generation on the coast are his, and he hangs his flayed victims from the masts of his ship.  "])
mechanic_one = Array[String](["Slave keeper. Can collect slaves after an attack; the slaves can be given to a city to greatly boost its productivity but keep in mind that slavery is outlawed. ", "Sea snake. Soldiers in this fleet fight with the strength of two. ", "Rallying through violence. Recruits 500 soldiers after a successful raid or battle by making a violent spectacle. "])
misc_list = Array[String]([""])
visible_to_none = false

