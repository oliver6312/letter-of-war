[node name="Great Woods" parent="Nature" unique_id=608578922 instance=ExtResource("2_6oxiq")]
position = Vector2(-517, -200)
token_name = "Great Woods"
natural = true
reputation = Array[String](["The great woods are the biggest and oldest forest in the land. Stretching from the Rein Ridges to the Deep, and from the green hills of Vervir to the fridge north. Many brave hunters and foragers enjoy the ancient groves' plentiful bounty at its edge, but few dare venture under the dark canopy. It is said that the old beasts and giants and fae still live deep within its heart. "])

[node name="Rein Ridge" parent="Nature" unique_id=1902997687 instance=ExtResource("2_6oxiq")]
position = Vector2(-839, -239)
token_name = "Rein Ridge"
natural = true
reputation = Array[String](["The rein ridges are uninhabited except for a few small hunting communities living among the many ridges of the mountain chain. They lay at the border of Vervir and continue deep into the north, no one knows exactly where it ends. "])

[node name="Crows Nest" parent="Nature" unique_id=198298306 instance=ExtResource("2_6oxiq")]
position = Vector2(-357, 388)
token_name = "Crows Nest"
natural = true
reputation = Array[String](["This short mountain range is mostly known for the many crows and ravens who nest here, and of course the shiny minerals that can be found under its rocky surface. This mountain is the most inhabited in these lands, with many small communities of goat herders, a small cloister and various isolated tribes. "])

[node name="Raven Wood" parent="Nature" unique_id=1360167120 instance=ExtResource("2_6oxiq")]
position = Vector2(-213, 520)
token_name = "Raven Wood"
natural = true
reputation = Array[String](["Sharing a border with three populated regions has put a strain on the wildlife and fruits of the forest. Overhunting has made these woods eerily quiet; soon only the wind will move these leaves. "])

[node name="Kings Wood" parent="Nature" unique_id=1486430047 instance=ExtResource("2_6oxiq")]
position = Vector2(216, 483)
token_name = "Kings Wood"
natural = true
reputation = Array[String](["Beautiful and lush greens, inhabited by noble creatures such as stags and stoats, these are truly rich woods. The king of Lydea has claimed these woods for himself, and others may only enter with permission. Despite the claim, many hungry hunters and greedy poachers stalk the woods. "])

[node name="Grey Peaks" parent="Nature" unique_id=1407289369 instance=ExtResource("2_6oxiq")]
position = Vector2(719, 499)
token_name = "Grey Peaks"
natural = true
reputation = Array[String](["The Grey Peaks only have one true mountain, but it is the tallest in the land, and it is said that whoever makes the journey to its peak, will be bestowed upon the wisdom of the mountain. Surrounding it are much smaller mountains, rich in iron and copper. "])

