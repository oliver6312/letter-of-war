position = Vector2(-647, 349)
token_name = "Salvardor Ashaux"
age = 62
army_size = 21000
sworn_to = 3
traits = Array[String](["Old", "Battle Scared", "Brave", "Respected", "Vigilant"])
reputation = Array[String](["He is a proud self-made man. Coming from foreign lands, trying his fortune in Port Braio, he has proven his worth at sea countless times. His house is still small, only ruling a few fishing villages near Port Braio. He has come a long way from the young lowborn sailor he once was. "])
