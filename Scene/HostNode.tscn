misc_list = Array[String](["House Taurus is in great depth to House Weave and the traders guild"])

[node name="Torr the Rabid" parent="Characters" unique_id=2115889601 instance=ExtResource("5_uu6iq")]
position = Vector2(224, -196)
token_name = "Torr the Rabid"
age = 25
sworn_to = 4
traits = Array[String](["Brutal", "Feared", "Loyal", "Battle Scared", "Insane"])
reputation = Array[String](["Torr the Rabid got his epithet from his many exploits in the civil war. He brutalized the entire coast of the Narrow. It is said that half of the coming generation on the coast are his, and he hangs his flayed victims from the masts of his ship.  "])
mechanic_one = Array[String](["Slave keeper. Can collect slaves after an attack; the slaves can be given to a city to greatly boost its productivity but keep in mind that slavery is outlawed. ", "Rallying through violence. Recruits 500 soldiers after a successful raid or battle by making a violent spectacle. ", "Sea snake. The army gets a 20-60% bonus if it’s attacking from the sea. ", "Dragon. Any combat bonus gotten from character mechanics is doubled. "])
misc_list = Array[String]([""])
visible_to_none = false

