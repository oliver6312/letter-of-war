steel_production = 150
gold_production = 350
food_production = 300
reputation = Array[String](["Home to the greatest castle in the lands and powerful trade guilds. The guilds control trade to such a degree that they manage to get a 5% cut from all gold produced in the land, and hand it over to their ruler. All this productivity is protected by the Lucerious Castle and the great red wall surronding the city. "])
function_one = Array[String](["Guild halls. Get 5% of the gold gained from all the other regions of this land", "Great Castle. This center has a great castle, which can house 5000 soldiers and any important character. If a city is under siege, the ruling lord and his most loyal followers can hide here until help arrives. "])

