token_name = "Silverhaven"
defense_bonus = 4.5
sworn_to = 1
steel_production = 50
gold_production = 300
food_production = 250
reputation = Array[String](["Silverhaven is the glinting pearl of the deep lake. The second largest castle, Queensten Castle, rests on a great white cliff, overlooking the Swordcourt, where the biggest tournaments are held.  "])
function_one = Array[String](["Queensten Castle. Gives royal legitmacy"])
function_two = Array[String](["Swordcourt. Can be used to host truly impressive tournaments"])

