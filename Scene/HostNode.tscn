steel_production = 50
gold_production = 300
food_production = 250
reputation = Array[String](["Silverhaven is the glinting pearl of the deep lake. The second largest castle, Queensten Castle, rests on a great white cliff, overlooking the Swordcourt, where the biggest tournaments are held.  "])
function_one = Array[String](["Swordcourt. Can be used to host truly impressive tournaments", "Great Castle. This center has a great castle, which can house 5000 soldiers and any important character. If a city is under siege, the ruling lord and his most loyal followers can hide here until help arrives. "])

